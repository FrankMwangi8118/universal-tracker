# If postgres is running on the host machine (not in Docker), use host.docker.internal
# If postgres is on a remote server, use its IP or hostname
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=tracker
DB_USERNAME=tracker_user
DB_PASSWORD=change_me_strong_password
